# Copy this to .env and fill in your values
# On Railway: set these in the Variables tab (do NOT commit .env to git)

BOT_TOKEN=your_telegram_bot_token_here
OTP_API_KEY=q6v6ef7r50mm4wkbkmq8a1ntxs8qx3wl

# ── Persistent storage (Railway) ───────────────────────────────────────────
# The bot stores everything in a SQLite file. Railway's filesystem is
# EPHEMERAL, so you MUST attach a Volume or your data resets on every deploy.
#   1. Railway > your service > Volumes > add a volume, mount path: /data
#   2. Set the variable below so the DB lives on that volume:
DB_PATH=/data/bot.db
